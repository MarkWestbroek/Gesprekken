# App mode
APP_ENV=development
GIN_MODE=debug

# Logging
BUNDEBUG=1

# Database connection
DATABASE_URL=postgres://<user>:<password>@localhost:5432/gesprekken_db?sslmode=disable

# Auto-create database on startup
AUTO_CREATE_DATABASE=true
DATABASE_ADMIN_URL=postgres://<user>:<password>@localhost:5432/postgres?sslmode=disable

# Server
PORT=8080

# MinIO object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gesprekken-documenten
MINIO_USE_SSL=false
