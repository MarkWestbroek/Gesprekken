{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gesprekken API (Gin debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "postDebugTask": "Stop Gesprekken API (poort 8080)",
      "env": {
        "GIN_MODE": "debug",
        "BUNDEBUG": "1"
      }
    }
  ]
}