{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Gesprekken API (zonder debug)",
      "type": "shell",
      "command": "go",
      "args": [
        "run",
        "main.go"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GIN_MODE": "release",
          "BUNDEBUG": "0"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "endsPattern": "^Gesprekken API gestart op .*$"
        }
      }
    },
    {
      "label": "Stop Gesprekken API (poort 8080)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$connection = Get-NetTCPConnection -LocalPort 8080 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1; if ($null -ne $connection) { Stop-Process -Id $connection.OwningProcess -Force; Write-Host ('Gestopt: proces ' + $connection.OwningProcess + ' op poort 8080'); } else { Write-Host 'Geen luisterend proces gevonden op poort 8080'; }"
      ],
      "problemMatcher": []
    },
    {
      "label": "Herstart Gesprekken API",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Stop Gesprekken API (poort 8080)",
        "Start Gesprekken API (zonder debug)"
      ],
      "problemMatcher": []
    }
  ]
}